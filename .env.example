# Telegram Bot Token — @BotFather orqali oling
BOT_TOKEN=your_telegram_bot_token_here

# Admin Telegram ID'lari, vergul bilan ajratilgan
# O'z ID'ingizni @userinfobot orqali bilib oling
ADMIN_IDS=123456789,987654321

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Misol (mahalliy): postgresql://postgres:postgres@localhost:5432/matem_bot
# Misol (cloud, SSL):   postgresql://user:pass@host:5432/db?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/matem_bot

# Agar serveringizda SSL talab qilinsa (Render, Supabase, Neon va h.k.) — true qilib qo'ying
# Ko'p hollarda DATABASE_URL'da ?sslmode=require yetadi va bu kerakmas.
PGSSL=false

# PDF fayllar saqlanadigan papka (zaxira nusxa uchun)
UPLOADS_DIR=./uploads
